# Copy to .env for local runs. Never put real secrets in committed files.

TRADING_FABRIC_LLM_PROVIDER=openai
TRADING_FABRIC_DEEP_THINK_LLM=gpt-5.4
TRADING_FABRIC_QUICK_THINK_LLM=gpt-5.4-mini
TRADING_FABRIC_EXECUTE=false
TRADING_FABRIC_DAILY_SPEND_CAP_USD=50
TRADING_FABRIC_MAX_POSITION_USD=25
TRADING_FABRIC_DATA_DIR=~/.trading-fabric/data
TRADING_FABRIC_RESULTS_DIR=~/.trading-fabric/results

# Provider keys are read by the selected provider implementation.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=

# Local Ollama profile.
# TRADING_FABRIC_LLM_PROVIDER=ollama
# TRADING_FABRIC_BACKEND_URL=http://localhost:11434/v1
# TRADING_FABRIC_DEEP_THINK_LLM=llama3.1:8b
# TRADING_FABRIC_QUICK_THINK_LLM=llama3.1:8b
